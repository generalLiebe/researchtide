# Semantic Scholar API Key (free, apply at https://www.semanticscholar.org/product/api#api-key-form)
S2_API_KEY=your_api_key_here

# OpenAlex polite pool email (optional, enables higher rate limits)
OPENALEX_EMAIL=your-email@example.com

# Dashboard cache TTL in seconds (default: 21600 = 6 hours). /live/dashboard は現状 TTL 超過でもキャッシュを返す。
DASHBOARD_CACHE_TTL=21600

# 1 でスケジュール full rebuild 後に live_keywords.json を再計算（SentenceTransformer 利用・512MB では無効推奨）
# RESEARCHTIDE_ENABLE_KEYWORD_CACHE=1

# CORS allowed origins (comma-separated for multiple)
RESEARCHTIDE_CORS_ORIGIN=http://localhost:5173
